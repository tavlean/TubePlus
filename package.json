{
    "name": "tubeplus",
    "version": "1.4.1",
    "description": "Browser extension that cleans YouTube Mix and playlist watch URLs",
    "private": true,
    "scripts": {
        "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
        "dev": "node scripts/build.js dev",
        "dev:chrome": "node scripts/build.js dev chrome",
        "dev:firefox": "node scripts/build.js dev firefox",
        "build": "node scripts/build.js build",
        "build:chrome": "node scripts/build.js build chrome",
        "build:firefox": "node scripts/build.js build firefox",
        "test": "node --test"
    },
    "keywords": [
        "chrome-extension",
        "firefox-extension",
        "browser-extension",
        "youtube"
    ],
    "license": "MIT"
}
